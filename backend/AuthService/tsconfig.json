{
  
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    
    "module": "nodenext",
    "target": "ES2020",
   
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

   
    "strict": true,
  
    "skipLibCheck": true,
  }
}
